{
  "name": "@nobet/db",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../apps/api/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../apps/api/.env -- drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.3",
    "drizzle-kit": "^0.30.1"
  }
}
