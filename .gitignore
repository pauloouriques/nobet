# =============================================================================
# Nobet — Git Ignore Rules
# =============================================================================

# Dependencies
**/node_modules
/apps/**/node_modules
.pnp
.pnp.js
.pnpm-store
/packages

# Testing
coverage/
*.lcov
.nyc_output

# Production builds
dist/
/apps/**/dist/
build/
out/
.next/
.vercel/

# Environment variables
.env
/apps/**/.evn
/apps/**/.env.local
/apps/**/.env.development.local
/apps/**/.env.test.local
/apps/**/.env.production.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep .env.example files
!.env.example
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Turborepo
.turbo/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
.cursor/

# Husky
!.husky/
.husky/_

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Compiled JavaScript (prevent accidental commits of compiled files in source directories)
# Allow config files but ignore everything else
**/*.js
**/*.js.map
!*.config.js
!*.config.*.js
!vite.config.js
!tailwind.config.js
!postcss.config.js

# Drizzle
drizzle/

# Database
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp

# Debug
npm-debug.log*
yarn-debug.log*
