# =============================================================================
# API Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Option A: Neon serverless (production / remote dev)
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Option B: Local Docker PostgreSQL (see docker-compose.yml in root)
DATABASE_URL=postgresql://nobet:nobet@localhost:5432/nobet

# ---------------------------------------------------------------------------
# Auth (Better Auth)
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Odds provider (sports & events)
# ---------------------------------------------------------------------------
# API key from your odds provider (e.g. https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here
# Base URL for the provider API (optional; change when switching providers)
ODDS_PROVIDER_BASE_URL=https://api.the-odds-api.com/v4

# ---------------------------------------------------------------------------
# Node Environment
# ---------------------------------------------------------------------------
NODE_ENV=development
